{
  "_description": "試合結果の取得先を種目別に定義。result_policyに従い必ずprimary_urlのみで勝敗を確定すること。",
  "_version": "1.0",
  "_updated": "2026-04-12",

  "result_policy": {
    "rule": "勝ち負けはprimary_urlのみで確定する。見つからない場合はhit=nullのまま保留。絶対に推測・補完・他ソースからの類推をしてはならない。",
    "fallback_rule": "primary_urlで結果が取得できなかった場合のみfallback_urlを使用。fallbackでも取れない場合はstatus=pendingを維持。",
    "context_rule": "スコア詳細・怪我情報・試合内容はcontext_sourcesから取得してよい。ただし勝敗の上書きには使用しない。"
  },

  "sports": {
    "tennis_atp": {
      "primary_url": "atptour.com/en/scores",
      "primary_note": "ATP公式スコアページ。試合終了後30分以内に確定スコアを掲載。",
      "fallback_url": "flashscore.com",
      "search_query_template": "site:atptour.com {player1} {player2} {tournament} {year} result",
      "context_sources": [
        "tennismajors.com",
        "tennisabstract.com",
        "tennisnerd.net",
        "perfect-tennis.com"
      ]
    },
    "tennis_wta": {
