  "note": "英国ラグビーリーグ Super League。NRLと同一競技規則のためNRL rules_nrl.json v1.0をベースに欧州仕様を追加。",
  "framework": "NRL準拠 4層フィルタリング",

  "L1": {
    "metric": "Points Differential per Game (PD/G)",
    "source": "superleague.co.uk / Wikipedia 2026 Super League table",
    "threshold_base": 6,
    "threshold_early_season": 12,
    "early_season_rounds": "R3-R8",
    "note": "NRL同一閾値を適用。早期シーズン（R3-R8）は12pt以上必要。データは公式サイトで週次更新。"
  },

  "rules": {
    "SL001": {
      "name": "PD/G L1スクリーニング",
      "desc": "ホーム・アウェイ合算PD/Gを使用。早期シーズン(R3-R8)は閾値12pt。シーズン後半は6pt。",
      "source": "superleague.co.uk league table"
    },
    "SL002": {
      "name": "早期シーズン補正",
      "desc": "R3-R8は小サンプルリスク。閾値12pt（NRL R012準拠）。信頼度推定にも-3%ペナルティ。"
    },
    "SL003": {
      "name": "ホームアドバンテージ補正",
      "desc": "ホームチーム +2-3%。Catalans Dragonsのフランス（ペルピニャン）ホームは特に強い（長距離移動の相手チームに-5%）。"
    },
    "SL004": {
      "name": "天候補正",
      "desc": "英国屋外スタジアム。強風・雨天時は大差がつきにくい（トライ数減少）。Windspeed >35km/h: -3%。Heavy rain: -2%。Weather forecast必須。"
    },
    "SL005": {
      "name": "17人スクワッド確認",
      "desc": "NHLゴーリー確認相当。通常試合前日（木〜金）に17人スクワッド発表。公式サイト/X(Twitter)で確認。主力欠場時は補正適用（N012準拠）。"
    },
    "SL006": {
      "name": "翻訳エラー警戒",
      "desc": "JSONの日本語チーム名に誤訳リスクあり。特にWarrington Wolves→ウェリントンウルフス（Wellington）誤訳事例あり。オッズと順位で照合して特定すること。"
    },
    "SL007": {
      "name": "信頼度閾値",
      "desc": "NRL準拠: 75%未満はSKIP。早期シーズン補正後の推定値で判定。"
    }
  },

